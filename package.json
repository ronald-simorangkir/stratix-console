{
  "name": "stratix-console",
  "version": "1.2.13",
  "description": "STRATIX Console — platform konsultan AI untuk analisis kesehatan perusahaan.",
  "author": "Mandiri Capital Indonesia",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always",
    "dist:msi": "electron-builder --win msi --x64"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.stratix.console",
    "productName": "STRATIX Console",
    "copyright": "Copyright © 2026 Mandiri Capital Indonesia",
    "files": [
      "main.js",
      "app/**/*",
      "build/icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "STRATIX-Console-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "STRATIX Console",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "STRATIX Console",
      "artifactName": "STRATIX-Console-${version}.${ext}"
    }
  }
}
